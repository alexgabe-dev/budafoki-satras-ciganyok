# APP_URL: Public URL of the site, used for self-referential links.
# Example: https://your-domain.com
APP_URL="https://your-domain.com"

# PORT: Port used by the Express server in production.
PORT="7878"

# NODE_ENV: Set to production for deployment.
NODE_ENV="production"

# SQLITE_PATH: Optional custom path for the ticket database.
# For VPS deployment, use a persistent absolute path such as:
# /var/www/budafoki-satras-ciganyok/data/tickets.sqlite
SQLITE_PATH="data/tickets.sqlite"

# ADMIN_TOKEN: Optional. If set, admin API calls must include this token.
ADMIN_TOKEN="change-this-secret"
